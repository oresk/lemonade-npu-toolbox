FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# ARGs must be declared before their first use in RUN instructions.
ARG FLM_VERSION=0.9.38

# All apt installs share one apt-get update so FastFlowLM deps (libavcodec60 etc.)
# are resolvable when installing the .deb. Clearing lists after all installs are done.
# amdxdna-dkms intentionally omitted — DKMS builds a kernel module that
# must be loaded on the host; not useful inside the container.
# rpm2cpio/cpio are needed to extract the lemonade-server RPM below.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      software-properties-common \
      curl \
      ca-certificates \
      python3-pip \
      python3 \
      rpm2cpio \
      cpio \
      libwebsockets-dev && \
    add-apt-repository ppa:amd-team/xrt && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
      libxrt-npu2 \
      libxrt-utils-npu && \
    # FastFlowLM — NPU-native LLM runtime for AMD XDNA2 (~52 tok/s @ 16K ctx)
    # Filename includes OS since v0.9.36: fastflowlm_<ver>_ubuntu24.04_amd64.deb
    # https://github.com/FastFlowLM/FastFlowLM
    curl -fsSL -o /tmp/fastflowlm.deb \
      "https://github.com/FastFlowLM/FastFlowLM/releases/download/v${FLM_VERSION}/fastflowlm_${FLM_VERSION}_ubuntu24.04_amd64.deb" && \
    apt-get install -y --no-install-recommends /tmp/fastflowlm.deb && \
    rm /tmp/fastflowlm.deb && \
    rm -rf /var/lib/apt/lists/*

# Ubuntu 24.04 ships libwebsockets.so.19; lemonade-server requires .so.20.
# ABI is compatible within the 4.x series — this symlink is safe.
RUN ln -sf /lib/x86_64-linux-gnu/libwebsockets.so.19 \
           /lib/x86_64-linux-gnu/libwebsockets.so.20 && ldconfig

# Lemonade Server (C++) — OpenAI-compatible API with FLM/llama.cpp backends.
# Distributed as RPM only; we extract and install binaries + resources manually.
# The lemonade-server-dev Python server was deprecated in v10 in favour of this.
# https://github.com/lemonade-sdk/lemonade
ARG LEMONADE_SERVER_VERSION=10.2.0
RUN curl -fsSL -o /tmp/lemonade-server.rpm \
      "https://github.com/lemonade-sdk/lemonade/releases/download/v${LEMONADE_SERVER_VERSION}/lemonade-server-${LEMONADE_SERVER_VERSION}.x86_64.rpm" && \
    cd /tmp && rpm2cpio /tmp/lemonade-server.rpm | cpio -idm 2>&1 | tail -2 || true && \
    cp /tmp/opt/bin/lemonade /tmp/opt/bin/lemonade-server /usr/local/bin/ && \
    cp -f /tmp/opt/bin/lemonade-web-app /tmp/opt/bin/lemond /usr/local/bin/ 2>/dev/null || true && \
    chmod +x /usr/local/bin/lemonade /usr/local/bin/lemonade-server && \
    # resources/ must sit next to lemonade-server (looked up relative to executable path)
    cp -a /tmp/opt/share/lemonade-server/resources /usr/local/bin/resources && \
    mkdir -p /etc/lemonade/conf.d && \
    cp -a /tmp/etc/lemonade/conf.d/. /etc/lemonade/conf.d/ 2>/dev/null || true && \
    mkdir -p /opt/var/lib/lemonade && \
    rm -rf /tmp/opt /tmp/etc /tmp/lemonade-server.rpm

# Lemonade SDK (Python) — flm-load CLI and benchmarking utilities.
# Also installs lemonade-server-dev (deprecated Python server, superseded above).
ARG LEMONADE_SDK_VERSION
RUN if [ -n "${LEMONADE_SDK_VERSION}" ]; then \
      pip3 install --break-system-packages "lemonade-sdk==${LEMONADE_SDK_VERSION}"; \
    else \
      pip3 install --break-system-packages lemonade-sdk; \
    fi

# /usr/local/bin is not on PATH in minimal Ubuntu LXC/containers
ENV PATH="/usr/local/bin:${PATH}"

# Model storage — mount your NPU model directory here at runtime:
#   -v /path/to/NPU-models:/mnt/models
ENV FLM_MODEL_PATH=/mnt/models

# Lemonade HTTP API
EXPOSE 8000
# Lemonade WebSocket bridge
EXPOSE 8100
# FastFlowLM direct inference API (used internally by lemonade-router)
EXPOSE 52625

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["bash"]
